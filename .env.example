# Required Telegram API credentials from https://my.telegram.org
API_ID=123456
API_HASH=your_api_hash

# Required bot token from @BotFather
BOT_TOKEN=123456:your_bot_token

# Required Pyrogram session string for the assistant/user account that joins VC
SESSION_STRING=your_pyrogram_session_string

# Optional but recommended for AI chat/quiz replies
GEMINI_API_KEY=your_gemini_api_key

# Optional
LOGGER_ID=-1003009782265
RUHI_DEFAULT_VOICE=hi-IN-SwaraNeural

# Optional weather replies
OPENWEATHER_API_KEY=your_openweather_key
